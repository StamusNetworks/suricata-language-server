alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"Potential DGA domain detected in TLS SNI"; flow:established,to_server; tls.sni; entropy:4.5,relative; threshold:type limit, track by_src, count 1, seconds 60; metadata:created_at 2026-03-03, updated_at 2026-03-03, written_by Eric Leblond; sid:1000001; rev:1;)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"Potential DGA domain detected in HTTP Host"; flow:established,to_server; http.host; entropy:4.5,relative; threshold:type limit, track by_src, count 1, seconds 60; metadata:created_at 2026-03-03, updated_at 2026-03-03, written_by Eric Leblond; sid:1000002; rev:1;)
